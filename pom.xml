<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.itexpert.content</groupId>
  <artifactId>itexpert-content</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <name>itexpert-content</name>
  <description>ITExpert Content</description>
  <packaging>pom</packaging>

  <modules>
    <module>itexpert-content-parent</module>
    <module>itexpert-content-lib</module>
    <module>itexpert-content-core</module>
    <module>itexpert-content-api</module>
    <module>itexpert-content-ui</module>
  </modules>

  <properties>
    <maven.compiler.source>21</maven.compiler.source>
    <maven.compiler.target>21</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    
    <!-- SonarQube Configuration -->
    <sonar.host.url>https://sonar.azirar.ovh</sonar.host.url>
    <sonar.sourceEncoding>UTF-8</sonar.sourceEncoding>
    <sonar.ws.ignoreCertificates>true</sonar.ws.ignoreCertificates>
    
    <!-- Java modules binaries -->
    <sonar.java.binaries>
      itexpert-content-parent/target/classes,
      itexpert-content-lib/target/classes,
      itexpert-content-core/target/classes,
      itexpert-content-api/target/classes
    </sonar.java.binaries>
    
    <!-- Java test binaries -->
    <sonar.java.test.binaries>
      itexpert-content-parent/target/test-classes,
      itexpert-content-lib/target/test-classes,
      itexpert-content-core/target/test-classes,
      itexpert-content-api/target/test-classes
    </sonar.java.test.binaries>
    
    <!-- Sources to analyze -->
    <sonar.sources>
      itexpert-content-parent/src/main,
      itexpert-content-lib/src/main,
      itexpert-content-core/src/main,
      itexpert-content-api/src/main,
      itexpert-content-ui/src
    </sonar.sources>
    
    <!-- Test sources -->
    <sonar.tests>
      itexpert-content-parent/src/test,
      itexpert-content-lib/src/test,
      itexpert-content-core/src/test,
      itexpert-content-api/src/test,
      itexpert-content-ui/src
    </sonar.tests>
    
    <!-- Exclusions -->
    <sonar.exclusions>
      **/node_modules/**,
      **/dist/**,
      **/*.spec.ts,
      **/*.test.ts,
      **/coverage/**,
      **/*.min.js
    </sonar.exclusions>
    
    <!-- Angular/TypeScript coverage -->
    <sonar.typescript.lcov.reportPaths>itexpert-content-ui/coverage/lcov.info</sonar.typescript.lcov.reportPaths>
    <sonar.javascript.lcov.reportPaths>itexpert-content-ui/coverage/lcov.info</sonar.javascript.lcov.reportPaths>
    
    <!-- Java coverage -->
    <sonar.coverage.jacoco.xmlReportPaths>
      itexpert-content-parent/target/site/jacoco/jacoco.xml,
      itexpert-content-lib/target/site/jacoco/jacoco.xml,
      itexpert-content-core/target/site/jacoco/jacoco.xml,
      itexpert-content-api/target/site/jacoco/jacoco.xml
    </sonar.coverage.jacoco.xmlReportPaths>
    
    <!-- Test reports -->
    <sonar.junit.reportPaths>
      itexpert-content-parent/target/surefire-reports,
      itexpert-content-lib/target/surefire-reports,
      itexpert-content-core/target/surefire-reports,
      itexpert-content-api/target/surefire-reports
    </sonar.junit.reportPaths>
  </properties>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.11.0</version>
          <configuration>
            <source>21</source>
            <target>21</target>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.sonarsource.scanner.maven</groupId>
          <artifactId>sonar-maven-plugin</artifactId>
          <version>3.10.0.2594</version>
        </plugin>
        <plugin>
          <groupId>org.jacoco</groupId>
          <artifactId>jacoco-maven-plugin</artifactId>
          <version>0.8.11</version>
        </plugin>
      </plugins>
    </pluginManagement>
    
    <plugins>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <executions>
          <execution>
            <id>prepare-agent</id>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>report</id>
            <phase>test</phase>
            <goals>
              <goal>report</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
